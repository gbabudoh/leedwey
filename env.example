# ============================================
# Leedwey B2B Platform - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# Database Configuration
# PostgreSQL connection string
#Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/leedwey?schema=public"

# NextAuth.js Configuration
# The base URL of your application
NEXTAUTH_URL="http://localhost:3000"
# Secret key for encrypting JWT tokens and sessions
# Generate a secure random string: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key-change-this-in-production"

# Algolia Search Configuration
# Get these from your Algolia dashboard: https://www.algolia.com/
NEXT_PUBLIC_ALGOLIA_APP_ID="your-algolia-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY="your-algolia-search-key"
ALGOLIA_ADMIN_KEY="your-algolia-admin-key"

# Cloudinary Image Upload Configuration
# Get these from your Cloudinary dashboard: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Stripe Payment Processing
# Get these from your Stripe dashboard: https://dashboard.stripe.com/
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# Socket.io Configuration
# URL for Socket.io server (usually same as your app URL)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# Daily.co Video/Audio Calls
# Get these from your Daily.co dashboard: https://dashboard.daily.co/
NEXT_PUBLIC_DAILY_API_KEY="your-daily-api-key"
DAILY_API_KEY="your-daily-api-key"

# Agora Video/Audio Calls (Alternative)
# Get these from your Agora dashboard: https://console.agora.io/
AGORA_APP_ID="your-agora-app-id"
AGORA_APP_CERTIFICATE="your-agora-app-certificate"

# Twilio SMS/Phone Verification
# Get these from your Twilio dashboard: https://console.twilio.com/
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Email Configuration (Nodemailer)
# SMTP settings for sending emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-email-app-password"
SMTP_FROM="Leedwey <noreply@leedwey.com>"

# Redis Configuration (Upstash)
# For rate limiting, caching, and real-time features
# Get these from your Upstash dashboard: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# UploadThing File Upload
# Get these from your UploadThing dashboard: https://uploadthing.com/
UPLOADTHING_SECRET="sk_live_your_uploadthing_secret"
UPLOADTHING_APP_ID="your_uploadthing_app_id"

# Jumio Identity Verification
# Get these from your Jumio dashboard: https://www.jumio.com/
JUMIO_API_TOKEN="your-jumio-api-token"
JUMIO_API_SECRET="your-jumio-api-secret"

# OneSignal Push Notifications
# Get these from your OneSignal dashboard: https://onesignal.com/
ONESIGNAL_APP_ID="your-onesignal-app-id"
ONESIGNAL_API_KEY="your-onesignal-api-key"

# PostHog Analytics
# Get these from your PostHog dashboard: https://posthog.com/
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Mixpanel Analytics
# Get these from your Mixpanel dashboard: https://mixpanel.com/
NEXT_PUBLIC_MIXPANEL_TOKEN="your-mixpanel-token"

# EasyPost Shipping API
# Get these from your EasyPost dashboard: https://www.easypost.com/
EASYPOST_API_KEY="your-easypost-api-key"

# ShipEngine Shipping API
# Get these from your ShipEngine dashboard: https://www.shipengine.com/
SHIPENGINE_API_KEY="your-shipengine-api-key"

# Application Configuration
# Node environment
NODE_ENV="development"

# Application URL (used for email links, etc.)
APP_URL="http://localhost:3000"

# Session Configuration
# Session cookie name
SESSION_COOKIE_NAME="leedwey.session"

# Rate Limiting
# Maximum requests per minute
RATE_LIMIT_MAX="100"

# File Upload Limits
# Maximum file size in bytes (10MB default)
MAX_FILE_SIZE="10485760"

# Email Verification
# Enable email verification for new users
ENABLE_EMAIL_VERIFICATION="true"

# Two-Factor Authentication
# Enable 2FA for users
ENABLE_2FA="true"

# Logging
# Enable detailed logging
ENABLE_LOGGING="true"
LOG_LEVEL="debug"

# ============================================
# Minimum Required for Development
# ============================================
# At minimum, you need these to get started:
# - DATABASE_URL (PostgreSQL connection)
# - NEXTAUTH_URL (your app URL)
# - NEXTAUTH_SECRET (generate with: openssl rand -base64 32)
#
# Other services can be added later as you integrate them.

# ============================================
# Production Overrides
# ============================================
# When deploying to production, update:
# - NEXTAUTH_URL to your production domain
# - DATABASE_URL to your production database
# - All API keys to production keys
# - NODE_ENV to "production"
# - Set secure, random values for all secrets

